{
  "name": "scaleme.js",
  "version": "0.1.0",
  "description": "A tiny, dependency-free charting library. Data → scales → pixels.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["chart", "charts", "graph", "canvas", "line-chart", "bar-chart", "dataviz"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
